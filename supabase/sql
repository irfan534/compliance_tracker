alter table companies enable row level security;
alter table certificates enable row level security;
alter table logs enable row level security;
alter table settings enable row level security;

-- 1. Multi-Tenant Isolation Policies
-- Companies: Accessible by owners or members
create policy "users_access_own_companies" on companies
  for all
  using (
    auth.uid() = owner_id or 
    exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
  );

-- Certificates: Inherit access from company
create policy "users_access_certificates" on certificates
  for all
  using (
    exists (
      select 1 from companies 
      where id = certificates.company_id and (
        owner_id = auth.uid() or 
        exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
      )
    )
  );

-- Logs: Viewable only for your companies
create policy "users_access_logs" on logs
  for select
  using (
    exists (
      select 1 from companies 
      where id = logs.company_id and (
        owner_id = auth.uid() or 
        exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
      )
    )
  );

-- Settings: Read-only for authenticated users
create policy "authenticated_read_settings" on settings
  for select
  to authenticated
  using (true);

-- Logs: Allow authenticated users to insert logs for companies they own or are members of
create policy "users_insert_logs" on logs
  for insert
  with check (
    exists (
      select 1 from companies
      where id = logs.company_id and (
        owner_id = auth.uid() or
        exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
      )
    )
  );

-- Settings: Allow authenticated users to update settings
create policy "authenticated_update_settings" on settings
  for update
  to authenticated
  using (true);

