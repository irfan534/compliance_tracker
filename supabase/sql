alter table companies enable row level security;
alter table certificates enable row level security;
alter table logs enable row level security;
alter table settings enable row level security;
alter table user_profiles enable row level security;

-- REPLACEMENT POLICIES: Enabling true Multi-Tenancy
-- This ensures that even if a server action is compromised, the DB layer protects the data.

-- Users can read their own profile
create policy "profiles_self_read" on user_profiles for select using (auth.uid() = id);

-- Companies: Accessible by owners or members
create policy "companies_tenant_isolation" on companies
  for all
  using (
    auth.uid() = owner_id or 
    exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
  );

-- Certificates: Inherit access from company membership
create policy "certificates_tenant_isolation" on certificates
  for all
  using (
    exists (
      select 1 from companies 
      where id = certificates.company_id and (
        owner_id = auth.uid() or 
        exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
      )
    )
  );

-- Logs: Users can only see logs related to companies they have access to
create policy "logs_tenant_isolation" on logs
  for all
  using (
    exists (
      select 1 from companies 
      where id = logs.company_id and (
        owner_id = auth.uid() or 
        exists (select 1 from company_members where company_id = companies.id and user_id = auth.uid())
      )
    )
  );

-- Settings: Read-only for all authenticated, update for admins only
create policy "settings_read" on settings for select to authenticated using (true);
create policy "settings_admin_update" on settings for update 
  using (exists (select 1 from user_profiles where id = auth.uid() and is_admin = true));

-- Storage Buckets: Set to private by default
insert into storage.buckets (id, name, public)
values ('company-logos', 'company-logos', false), ('cert-logos', 'cert-logos', false)
on conflict (id) do nothing;

-- Storage: Dynamic policies based on company folder ownership
-- Allows users to upload/read only files within their company's scope
create policy "storage_authenticated_read" on storage.objects
  for select to authenticated using (true); -- Read access handled by signed URLs in code

create policy "storage_tenant_upload" on storage.objects
  for insert to authenticated
  with check (
    bucket_id in ('company-logos', 'cert-logos') and
    (substring(name from '^([^/]+)') :: uuid) in (
      select id from companies where owner_id = auth.uid()
      union
      select company_id from company_members where user_id = auth.uid()
    )
  );
