#!/bin/bash

# ComplianceTracker Start Script
# Starts the Next.js dev server for localhost testing

set -e

if [ "${EUID:-$(id -u)}" -eq 0 ] || [ -n "${SUDO_USER:-}" ]; then
    echo "❌ Error: do not run this script with sudo"
    echo ""
    echo "Use:"
    echo "  ./start"
    exit 1
fi

echo "🚀 Starting ComplianceTracker..."
echo ""

# Check if .env.local exists
if [ ! -f "frontend/.env.local" ]; then
    echo "❌ Error: frontend/.env.local not found"
    echo ""
    echo "Please create frontend/.env.local with:"
    echo "  NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co"
    echo "  NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key"
    echo ""
    echo "See SETUP.md for detailed instructions."
    exit 1
fi

# Navigate to frontend directory
cd frontend

# Rotate stale Next.js artifacts out of the way to avoid mixed prod/dev cache corruption
if [ -d ".next-runtime" ]; then
    stale_dir=".next-runtime.stale.$(date +%s)"
    echo "♻️ Rotating stale Next.js runtime cache to ${stale_dir}..."
    mv .next-runtime "${stale_dir}"
    echo ""
fi

if [ -d ".next.sudo-bak" ]; then
    echo "⚠️ Found leftover sudo-owned cache at frontend/.next.sudo-bak"
    echo "   It is being ignored for this run."
    echo ""
fi

if [ -d ".next" ]; then
    echo "⚠️ Found legacy Next.js cache at frontend/.next"
    echo "   The app now uses frontend/.next-runtime instead."
    echo ""
fi

# Check if node_modules exists, if not install dependencies
if [ ! -d "node_modules" ]; then
    echo "📦 Installing dependencies..."
    npm install
    echo ""
fi

# Start the dev server
echo "✅ Starting dev server on http://localhost:3000"
echo "📝 Logs:"
echo ""

npm run dev
