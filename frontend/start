#!/bin/bash

# ComplianceTracker Frontend Start Script
# Run from frontend directory to start dev server

set -e

echo "🚀 Starting ComplianceTracker Frontend..."
echo ""

# Check if .env.local exists
if [ ! -f ".env.local" ]; then
    echo "❌ Error: .env.local not found in frontend/"
    echo ""
    echo "Please create frontend/.env.local with:"
    echo "  NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co"
    echo "  NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key"
    echo ""
    exit 1
fi

# Check if node_modules exists
if [ ! -d "node_modules" ]; then
    echo "📦 Installing dependencies..."
    npm install
    echo ""
fi

# Start the dev server
echo "✅ Dev server starting on http://localhost:3000"
echo "📝 Logs:"
echo ""

npm run dev
